[Unit]
Description=Run WhisperX on latest lesson recording

[Service]
Type=oneshot
User=bojinda
WorkingDirectory=/home/bojinda/meeting-pipeline
ExecStart=/bin/bash -lc 'LATEST="$(cat /home/bojinda/meeting-pipeline/lesson-recordings/last_recording.txt)" && /home/bojinda/meeting-pipeline/bin/postprocess-lesson.sh "$LATEST"'
TimeoutStartSec=infinity