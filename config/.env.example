HF_TOKEN=huggingface read token here
WHISPERX_MODEL=large-v2
WHISPERX_BATCH_SIZE=4
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_DEVICE=cuda

# optional: if you usually know the speaker count, uncomment these
# WHISPERX_MIN_SPEAKERS=2
# WHISPERX_MAX_SPEAKERS=8

TRANSCRIPT_CHUNK_TARGET_WORDS=1400
TRANSCRIPT_CHUNK_MAX_WORDS=2200

DELETE_SOURCE_AUDIO_AFTER_TRANSCRIPTION=1

OLLAMA_URL=url to ollama
OLLAMA_MAP_MODEL=qwen2.5:32b
OLLAMA_REDUCE_MODEL=qwen2.5:32b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAP_NUM_CTX=16384
OLLAMA_REDUCE_NUM_CTX=32768

LESSON_RECORDINGS_ROOT=/$HOME/meeting-pipeline/lesson-recordings
LESSON_TRANSCRIPTS_ROOT=/$HOME/meeting-pipeline/lesson-transcripts
LESSON_SUMMARIES_ROOT=/$HOME/meeting-pipeline/lesson-summaries
MEETING_SUMMARIES_ROOT=$HOME/meeting-pipeline/meeting-summaries

WINDOWS_HOST=audio host ip
WINDOWS_USER=username
WINDOWS_SSH_KEY=/path/to/.ssh/key

WINDOWS_START_TASK=task start name
WINDOWS_STOP_SCRIPT=C:/path/to/stop-meeting-audio.ps1

MEETING_CONTROL_LOG=/home/bojinda/meeting-pipeline/meeting-control.log

LESSON_STATE_DIR=/home/bojinda/meeting-pipeline/lesson-state
LESSON_CONTROLLER_HOST=0.0.0.0
LESSON_CONTROLLER_PORT=8765
LESSON_CONTROLLER_API_KEY=replace-this-with-a-random-string
LESSON_CONTROLLER_SCRIPT_TIMEOUT=30