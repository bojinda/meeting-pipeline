# Linux listener settings
LISTEN_HOST=0.0.0.0
LISTEN_PORT=4000
SAMPLE_RATE=16000
CHANNELS=1

# Output directories
RECORDINGS_DIR=/home/bojinda/meeting-pipeline/meeting-recordings
TRANSCRIPTS_DIR=/home/bojinda/meeting-pipeline/meeting-transcripts
SUMMARIES_DIR=/home/bojinda/meeting-pipeline/meeting-summaries

# Ollama
OLLAMA_URL=http://192.168.0.105:11434
OLLAMA_MODEL=qwen2.5:14b

# WhisperX / diarization
WHISPERX_MODEL=large-v2
ENABLE_DIARIZATION=true

